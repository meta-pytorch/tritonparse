{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "launch.schema.json",
  "title": "TritonParse Launch Event",
  "description": "Event emitted when a compiled Triton kernel is launched on the GPU.",
  "type": "object",
  "required": ["event_type", "pid", "timestamp", "name", "grid"],
  "additionalProperties": true,
  "properties": {
    "event_type": {
      "type": "string",
      "enum": ["launch"],
      "description": "Event type discriminator."
    },
    "pid": {
      "type": "integer",
      "minimum": 0,
      "description": "Process ID that launched the kernel."
    },
    "timestamp": {
      "type": "string",
      "description": "ISO 8601 timestamp of the launch event."
    },
    "stack": {
      "type": "array",
      "description": "Call stack trace at the time of launch.",
      "items": { "$ref": "#/definitions/StackFrame" }
    },
    "name": {
      "type": "string",
      "description": "Kernel name."
    },
    "function": {
      "type": ["integer", "null"],
      "description": "Kernel function handle (memory address), or null if not captured."
    },
    "stream": {
      "type": "integer",
      "minimum": 0,
      "description": "CUDA/HIP stream number."
    },
    "grid": {
      "type": "array",
      "description": "Grid dimensions for the kernel launch.",
      "items": { "type": "integer", "minimum": 0 }
    },
    "compilation_metadata": {
      "type": "object",
      "description": "Compilation metadata from the corresponding compilation event. Fields are defined by Triton.",
      "additionalProperties": true,
      "properties": {
        "hash": {
          "type": "string",
          "description": "Unique kernel hash identifying the compilation."
        },
        "name": {
          "type": "string",
          "description": "Kernel name."
        }
      }
    },
    "extracted_args": {
      "type": "object",
      "description": "Detailed information about each kernel argument, keyed by argument name.",
      "additionalProperties": { "$ref": "#/definitions/ArgInfo" }
    },
    "extracted_inductor_args": {
      "type": "object",
      "description": "Inductor-specific arguments (if applicable).",
      "additionalProperties": true
    },
    "occurrence_id": {
      "type": "integer",
      "minimum": 0,
      "description": "Global ordering index across all events (added during processing)."
    },
    "launch_group_hash": {
      "type": "string",
      "description": "SHA-256 hash (16 chars) for grouping equivalent launches (added during processing)."
    },
    "autotune_launch_type": {
      "type": "string",
      "enum": ["benchmark", "winner", "cached_winner"],
      "description": "Autotune launch classification (added during processing)."
    }
  },
  "definitions": {
    "StackFrame": {
      "type": "object",
      "description": "A single frame in the call stack.",
      "required": ["line", "name", "filename"],
      "additionalProperties": false,
      "properties": {
        "line": {
          "type": "integer",
          "description": "Line number in the source file."
        },
        "name": {
          "type": "string",
          "description": "Function name."
        },
        "filename": {
          "type": "string",
          "description": "Source file path."
        },
        "loc": {
          "type": "string",
          "description": "Code snippet at that line."
        }
      }
    },
    "ArgInfo": {
      "type": "object",
      "description": "Information about a single kernel argument. Fields vary by argument type.",
      "required": ["type"],
      "additionalProperties": true,
      "properties": {
        "type": {
          "type": "string",
          "description": "Argument type: 'tensor', 'int', 'float', 'bool', 'TensorDescriptor', etc."
        },
        "shape": {
          "type": "array",
          "description": "Tensor shape (for tensor arguments).",
          "items": { "type": "integer" }
        },
        "dtype": {
          "type": "string",
          "description": "Data type string (for tensor arguments, e.g., 'torch.float16')."
        },
        "device": {
          "type": "string",
          "description": "Device string (for tensor arguments, e.g., 'cuda:0')."
        },
        "stride": {
          "type": "array",
          "description": "Tensor strides (for tensor arguments).",
          "items": { "type": "integer" }
        },
        "numel": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of elements (for tensor arguments)."
        },
        "is_contiguous": {
          "type": "boolean",
          "description": "Whether the tensor is contiguous in memory."
        },
        "element_size": {
          "type": "integer",
          "minimum": 1,
          "description": "Size of each element in bytes."
        },
        "storage_offset": {
          "type": "integer",
          "minimum": 0,
          "description": "Storage offset."
        },
        "memory_usage": {
          "type": "integer",
          "minimum": 0,
          "description": "Total memory usage in bytes."
        },
        "data_ptr": {
          "type": "string",
          "description": "Data pointer as hex string."
        },
        "value": {
          "description": "Scalar value (for int, float, or bool arguments)."
        }
      }
    }
  }
}
